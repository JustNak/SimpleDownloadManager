            Text {
                text: details.filename;
                font-size: 16px;
                font-weight: 700;
                color: #111827;
                overflow: elide;
            }

            MetaLine { label: "State"; value: details.state; }
            MetaLine { label: "Bytes"; value: details.bytes-text; }
            ProgressLine { progress: details.progress; }

            Text {
                text: details.error-text;
                color: #b91c1c;
