    callback resume-job-requested(string);
    callback cancel-job-requested(string);
    callback retry-job-requested(string);
    callback restart-job-requested(string);
    callback pause-all-requested();
    callback resume-all-requested();
    callback retry-failed-requested();
    callback clear-completed-requested();
    callback open-progress-requested(string);
    callback check-update-requested();
    callback install-update-requested();
    callback settings-requested();
    callback settings-section-requested(string);
    callback settings-save-requested();
    callback settings-cancel-requested();
    callback settings-discard-confirmed();
    callback settings-unsaved-cancelled();
    callback settings-browse-download-directory-requested();
    callback settings-browse-torrent-directory-requested();
    callback settings-clear-torrent-cache-requested();
    callback settings-download-directory-changed(string);
    callback settings-max-concurrent-downloads-changed(string);
    callback settings-auto-retry-attempts-changed(string);
    callback settings-speed-limit-kib-per-second-changed(string);
    callback settings-download-performance-mode-changed(string);
    callback settings-notifications-enabled-changed(bool);
    callback settings-show-details-on-click-changed(bool);
    callback settings-queue-row-size-changed(string);
    callback settings-start-on-startup-changed(bool);
    callback settings-startup-launch-mode-changed(string);
    callback settings-theme-changed(string);
    callback settings-accent-color-changed(string);
    callback settings-torrent-enabled-changed(bool);
    callback settings-torrent-download-directory-changed(string);
    callback settings-torrent-seed-mode-changed(string);
    callback settings-torrent-seed-ratio-limit-changed(string);
    callback settings-torrent-seed-time-limit-minutes-changed(string);
    callback settings-torrent-upload-limit-kib-per-second-changed(string);
    callback settings-torrent-port-forwarding-enabled-changed(bool);
    callback settings-torrent-port-forwarding-port-changed(string);
    callback settings-torrent-peer-watchdog-mode-changed(string);
    callback settings-extension-enabled-changed(bool);
    callback settings-extension-handoff-mode-changed(string);
    callback settings-extension-listen-port-changed(string);
    callback settings-extension-context-menu-enabled-changed(bool);
    callback settings-extension-show-progress-after-handoff-changed(bool);
    callback settings-extension-show-badge-status-changed(bool);
    callback settings-extension-authenticated-handoff-enabled-changed(bool);
    callback settings-extension-excluded-host-input-changed(string);
    callback settings-extension-excluded-host-add-requested();
    callback settings-extension-excluded-host-remove-requested(string);
    callback diagnostics-refresh-requested();
    callback diagnostics-copy-requested();
    callback diagnostics-export-requested();
    callback diagnostics-open-install-docs-requested();
    callback diagnostics-repair-host-requested();
    callback diagnostics-test-handoff-requested();
    callback toast-dismiss-requested(string);
    callback minimize-main-window-requested();
    callback toggle-main-window-maximize-requested();
    callback close-main-window-requested();
    callback start-main-window-drag-requested();
    callback titlebar-double-clicked();

    VerticalBox {
        spacing: 0px;

        Rectangle {
            height: 44px;
            horizontal-stretch: 1;
            background: #111827;

            HorizontalBox {
                spacing: 0px;
                padding-left: 0px;
                padding-right: 0px;

                Rectangle {
                    width: 220px;
                    background: #0f766e;

                    TouchArea {
                        pointer-event(event) => {
                            if (event.button == PointerEventButton.left && event.kind == PointerEventKind.down) {
                                root.start-main-window-drag-requested();
                            }
                        }
                        double-clicked => {
                            root.titlebar-double-clicked();
                        }
                    }

                    Text {
                        text: "Download Manager";
                        color: #ffffff;
                        font-size: 14px;
                        font-weight: 700;
                        vertical-alignment: center;
                        x: 16px;
                        y: 0px;
                        width: parent.width - 32px;
                        height: parent.height;
                        overflow: elide;
                    }
                }

                Rectangle {
                    horizontal-stretch: 1;
                    background: #111827;

                    TouchArea {
                        pointer-event(event) => {
                            if (event.button == PointerEventButton.left && event.kind == PointerEventKind.down) {
                                root.start-main-window-drag-requested();
                            }
                        }
                        double-clicked => {
                            root.titlebar-double-clicked();
                        }
                    }

                    Text {
                        text: "Simple Download Manager";
                        color: #f9fafb;
                        font-size: 13px;
                        vertical-alignment: center;
                        x: 14px;
                        y: 0px;
                        width: parent.width - 28px;
                        height: parent.height;
                        overflow: elide;
                    }
                }

                Button {
                    text: "_";
                    width: 48px;
                    clicked => {
                        root.minimize-main-window-requested();
                    }
                }

                Button {
                    text: root.main-window-maximized ? "Restore" : "Max";
                    width: 72px;
                    clicked => {
                        root.toggle-main-window-maximize-requested();
                    }
                }

                Button {
                    text: "X";
                    width: 48px;
                    clicked => {
                        root.close-main-window-requested();
                    }
                }
            }
        }

        VerticalBox {
            padding: 18px;
            spacing: 12px;

            HorizontalBox {
                spacing: 10px;

                Text {
                    text: root.queue-title;
                    font-size: 22px;
                    font-weight: 700;
                    horizontal-stretch: 1;
                }

                Button {
                    text: "Add";
                    clicked => {
                        root.add-download-requested();
                    }
                }

                Button {
                    text: "Settings";
                    clicked => {
                        root.settings-requested();
                    }
                }
            }

            Text {
                text: root.status-text + " | " + root.queue-subtitle;
                color: #586174;
                font-size: 13px;
            }

            Rectangle {
                border-color: #d5dae3;
                border-width: 1px;
                border-radius: 6px;
                background: #ffffff;
                height: 96px;
                horizontal-stretch: 1;

                HorizontalBox {
                    padding-left: 14px;
                    padding-right: 14px;
                    spacing: 12px;

                    VerticalBox {
                        horizontal-stretch: 1;
                        spacing: 4px;

                        Text {
                            text: root.update-status-text;
                            font-size: 14px;
                            font-weight: 700;
                            color: #111827;
                            overflow: elide;
                        }

                        Text {
                            text: "Current " + root.update-current-version + " | Latest " + root.update-new-version;
                            font-size: 11px;
                            color: #586174;
                            overflow: elide;
                        }

                        Text {
                            text: root.update-body;
                            font-size: 11px;
                            color: #374151;
                            overflow: elide;
                            visible: root.update-body != "";
                        }

                        Text {
                            text: root.update-progress-text;
                            font-size: 11px;
                            color: #2563eb;
                            overflow: elide;
                            visible: root.update-progress-text != "";
                        }

                        Text {
                            text: root.update-error-text;
                            font-size: 11px;
                            color: #b91c1c;
                            overflow: elide;
                            visible: root.update-error-text != "";
                        }
                    }

                    Button {
                        text: "Check";
                        enabled: root.update-can-check;
                        clicked => {
                            root.check-update-requested();
                        }
                    }

                    Button {
                        text: "Install";
                        enabled: root.update-can-install;
                        clicked => {
                            root.install-update-requested();
                        }
                    }
                }
            }

            HorizontalBox {
                spacing: 12px;
                vertical-stretch: 1;

                Rectangle {
                    width: 220px;
                    border-color: #d5dae3;
                    border-width: 1px;
                    border-radius: 6px;
                    background: #ffffff;

                    ListView {
                        viewport-width: parent.width;
                        viewport-height: parent.height;

                        for item in root.nav-items: Rectangle {
                            height: 34px;
                            width: parent.width;
                            background: item.active ? #e0f2fe : #ffffff;

                            TouchArea {
                                clicked => {
                                    root.view-change-requested(item.id);
                                }
                            }

                            HorizontalBox {
                                padding-left: 10px;
                                padding-right: 10px;
                                spacing: 8px;

                                Text {
                                    text: item.label;
                                    font-size: 12px;
                                    font-weight: item.active ? 700 : 400;
                                    color: item.active ? #075985 : #1f2937;
                                    horizontal-stretch: 1;
                                    overflow: elide;
                                }

                                Text {
                                    text: item.count;
                                    font-size: 11px;
                                    color: #586174;
                                    horizontal-alignment: right;
                                    width: 34px;
                                }
                            }
                        }
                    }
                }

                VerticalBox {
                    spacing: 8px;
                    horizontal-stretch: 1;
                    vertical-stretch: 1;

                    Rectangle {
                        height: 42px;
                        horizontal-stretch: 1;

                        HorizontalBox {
                            spacing: 8px;

                            LineEdit {
                                text: root.queue-search-query;
                                placeholder-text: "Search downloads";
                                horizontal-stretch: 1;
                                edited => {
                                    root.search-query-changed(self.text);
                                }
                            }

                            Button {
                                text: root.queue-sort-column == "name" ? "Name " + root.queue-sort-direction : "Name";
                                clicked => {
                                    root.sort-column-requested("name");
                                }
                            }

                            Button {
                                text: root.queue-sort-column == "date" ? "Date " + root.queue-sort-direction : "Date";
                                clicked => {
                                    root.sort-column-requested("date");
                                }
                            }

                            Button {
                                text: root.queue-sort-column == "size" ? "Size " + root.queue-sort-direction : "Size";
                                clicked => {
                                    root.sort-column-requested("size");
                                }
                            }
                        }
                    }

                    Rectangle {
                        height: 42px;
                        horizontal-stretch: 1;

                        HorizontalBox {
                            spacing: 8px;

                            Button {
                                text: root.queue-all-visible-selected ? "Clear visible" : "Select visible";
                                clicked => {
                                    root.select-all-visible-requested(!root.queue-all-visible-selected);
                                }
                            }

                            Button {
                                text: "Clear selection";
                                enabled: root.queue-selected-count > 0;
                                clicked => {
                                    root.clear-selection-requested();
                                }
                            }

                            Text {
                                text: root.queue-selected-count + " selected";
                                color: #586174;
                                font-size: 12px;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                            }

                            Button { text: "Pause all"; clicked => { root.pause-all-requested(); } }
                            Button { text: "Resume all"; clicked => { root.resume-all-requested(); } }
                            Button { text: "Retry failed"; clicked => { root.retry-failed-requested(); } }
                            Button { text: "Clear done"; clicked => { root.clear-completed-requested(); } }
                            Button {
                                text: "Delete selected";
                                enabled: root.queue-selected-count > 0;
                                clicked => {
                                    root.request-delete-selected();
                                }
                            }
                        }
                    }

                    Rectangle {
                        border-color: #d5dae3;
                        border-width: 1px;
                        border-radius: 6px;
                        background: #ffffff;
                        horizontal-stretch: 1;
                        vertical-stretch: 1;

                        Text {
                            text: root.queue-empty-text;
                            visible: root.jobs.length == 0;
                            color: #586174;
                            font-size: 13px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            width: parent.width;
                            height: parent.height;
                        }

                        ListView {
                            viewport-width: parent.width;
                            viewport-height: parent.height;

                            for job in root.jobs: Rectangle {
                                height: 92px;
                                width: parent.width;
                                background: job.selected ? #eef6ff : #ffffff;

                                TouchArea {
                                    clicked => {
                                        root.job-selection-requested(job.id);
                                    }
                                }

                                HorizontalBox {
                                    padding-left: 14px;
                                    padding-right: 14px;
                                    spacing: 10px;

                                    Button {
                                        text: job.selected ? "On" : "Off";
                                        width: 46px;
                                        clicked => {
                                            root.job-selection-toggled(job.id, !job.selected);
                                        }
                                    }

                                    VerticalBox {
                                        horizontal-stretch: 1;
                                        spacing: 4px;

                                        Text {
                                            text: job.filename;
                                            font-size: 15px;
                                            color: #111827;
                                            overflow: elide;
                                        }

                                        Text {
                                            text: job.state + " | " + job.bytes-text + " | " + job.transfer-kind;
                                            font-size: 12px;
                                            color: job.status-tone == "attention" ? #b91c1c : #586174;
                                            overflow: elide;
                                        }

                                        Text {
                                            text: job.size-text + (job.speed-text == "" ? "" : " | " + job.speed-text) + (job.status-detail == "" ? "" : " | " + job.status-detail);
                                            font-size: 11px;
                                            color: #6b7280;
                                            overflow: elide;
                                        }
                                    }

                                    Button { text: "Pause"; enabled: job.can-pause; clicked => { root.pause-job-requested(job.id); } }
                                    Button { text: "Resume"; enabled: job.can-resume; clicked => { root.resume-job-requested(job.id); } }
                                    Button { text: "Cancel"; enabled: job.can-cancel; clicked => { root.cancel-job-requested(job.id); } }
                                    Button { text: "Retry"; enabled: job.can-retry; clicked => { root.retry-job-requested(job.id); } }
                                    Button { text: "Restart"; enabled: job.can-restart; clicked => { root.restart-job-requested(job.id); } }
                                    Button { text: "Details"; enabled: job.can-show-progress; clicked => { root.open-progress-requested(job.id); } }
                                    Button { text: "Open"; enabled: job.can-open; clicked => { root.open-job-file-requested(job.id); } }
                                    Button { text: "Folder"; enabled: job.can-reveal; clicked => { root.reveal-job-requested(job.id); } }
                                    Button { text: "Swap"; visible: job.can-swap-to-browser; clicked => { root.swap-failed-to-browser-requested(job.id); } }
                                    Button { text: "Rename"; enabled: job.can-rename; clicked => { root.request-rename-job(job.id); } }
                                    Button { text: job.delete-label; enabled: job.can-remove; clicked => { root.request-delete-job(job.id); } }
                                }
                            }
                        }
                    }

                    Text {
                        text: root.queue-footer-text;
                        color: #586174;
                        font-size: 12px;
                    }
                }
            }
        }
    }

    Rectangle {
        visible: root.settings-view-visible;
        width: root.width;
        height: root.height - 44px;
        y: 44px;
        background: #f8fafc;

        VerticalBox {
            padding: 18px;
            spacing: 12px;

            HorizontalBox {
                spacing: 10px;

                VerticalBox {
                    horizontal-stretch: 1;
                    spacing: 2px;
                    Text { text: "Settings"; font-size: 22px; font-weight: 700; color: #111827; }
                    Text { text: root.settings-dirty ? "Unsaved changes" : "Preferences are up to date"; font-size: 12px; color: root.settings-dirty ? #b45309 : #586174; }
                }

                Button { text: "Cancel"; clicked => { root.settings-cancel-requested(); } }
                Button { text: root.settings-saving ? "Saving..." : "Save"; enabled: root.settings-dirty && !root.settings-saving; clicked => { root.settings-save-requested(); } }
            }

            Text {
                visible: root.settings-error-text != "";
                text: root.settings-error-text;
                color: #b91c1c;
                font-size: 12px;
            }

            HorizontalBox {
                spacing: 12px;
                vertical-stretch: 1;

                Rectangle {
                    width: 220px;
                    border-color: #d5dae3;
                    border-width: 1px;
                    border-radius: 6px;
                    background: #ffffff;

                    ListView {
                        viewport-width: parent.width;
                        viewport-height: parent.height;

                        for section in root.settings-sections: Rectangle {
                            height: 36px;
                            width: parent.width;
                            background: section.active ? #e0f2fe : #ffffff;

                            TouchArea {
                                clicked => {
                                    root.settings-section-requested(section.id);
                                }
                            }

                            Text {
                                text: section.label;
                                font-size: 12px;
                                font-weight: section.active ? 700 : 400;
                                color: section.active ? #075985 : #1f2937;
                                x: 10px;
                                y: 0px;
                                width: parent.width - 20px;
                                height: parent.height;
                                vertical-alignment: center;
                                overflow: elide;
                            }
                        }
                    }
                }

                Rectangle {
                    border-color: #d5dae3;
                    border-width: 1px;
                    border-radius: 6px;
                    background: #ffffff;
                    horizontal-stretch: 1;
                    vertical-stretch: 1;

                    VerticalBox {
                        padding: 16px;
                        spacing: 10px;

                        VerticalBox {
                            visible: root.settings-active-section == "general";
                            spacing: 8px;
                            Text { text: "General"; font-size: 16px; font-weight: 700; color: #111827; }
                            Text { text: "Download directory"; font-size: 12px; color: #374151; }
                            HorizontalBox {
                                spacing: 8px;
                                LineEdit { text: root.settings-download-directory; horizontal-stretch: 1; edited => { root.settings-download-directory-changed(self.text); } }
                                Button { text: "Browse"; clicked => { root.settings-browse-download-directory-requested(); } }
                            }
                            HorizontalBox {
                                spacing: 8px;
                                LineEdit { text: root.settings-max-concurrent-downloads; placeholder-text: "Concurrent"; edited => { root.settings-max-concurrent-downloads-changed(self.text); } }
                                LineEdit { text: root.settings-auto-retry-attempts; placeholder-text: "Retries"; edited => { root.settings-auto-retry-attempts-changed(self.text); } }
                                LineEdit { text: root.settings-speed-limit-kib-per-second; placeholder-text: "KiB/s limit"; edited => { root.settings-speed-limit-kib-per-second-changed(self.text); } }
                            }
                            Text { text: "Performance mode"; font-size: 12px; color: #374151; }
                            HorizontalBox {
                                spacing: 6px;
                                Button { text: "Stable"; checked: root.settings-download-performance-mode == "stable"; clicked => { root.settings-download-performance-mode-changed("stable"); } }
                                Button { text: "Balanced"; checked: root.settings-download-performance-mode == "balanced"; clicked => { root.settings-download-performance-mode-changed("balanced"); } }
                                Button { text: "Fast"; checked: root.settings-download-performance-mode == "fast"; clicked => { root.settings-download-performance-mode-changed("fast"); } }
                            }
                            CheckBox { text: "Show notifications"; checked: root.settings-notifications-enabled; toggled => { root.settings-notifications-enabled-changed(self.checked); } }
                            CheckBox { text: "Show details when clicking a download"; checked: root.settings-show-details-on-click; toggled => { root.settings-show-details-on-click-changed(self.checked); } }
                            Text { text: "Queue row size"; font-size: 12px; color: #374151; }
                            HorizontalBox {
                                spacing: 6px;
                                Button { text: "Compact"; checked: root.settings-queue-row-size == "compact"; clicked => { root.settings-queue-row-size-changed("compact"); } }
                                Button { text: "Small"; checked: root.settings-queue-row-size == "small"; clicked => { root.settings-queue-row-size-changed("small"); } }
                                Button { text: "Medium"; checked: root.settings-queue-row-size == "medium"; clicked => { root.settings-queue-row-size-changed("medium"); } }
                                Button { text: "Large"; checked: root.settings-queue-row-size == "large"; clicked => { root.settings-queue-row-size-changed("large"); } }
                                Button { text: "Damn"; checked: root.settings-queue-row-size == "damn"; clicked => { root.settings-queue-row-size-changed("damn"); } }
                            }
                        }

                        VerticalBox {
                            visible: root.settings-active-section == "updates";
                            spacing: 8px;
                            Text { text: "App Updates"; font-size: 16px; font-weight: 700; color: #111827; }
                            Text { text: root.update-status-text; font-size: 13px; color: #111827; }
                            Text { text: "Current " + root.update-current-version + " | Latest " + root.update-new-version; font-size: 12px; color: #586174; }
                            Text { text: root.update-error-text; visible: root.update-error-text != ""; font-size: 12px; color: #b91c1c; }
                            HorizontalBox {
                                spacing: 8px;
                                Button { text: "Check"; enabled: root.update-can-check; clicked => { root.check-update-requested(); } }
                                Button { text: "Install"; enabled: root.update-can-install; clicked => { root.install-update-requested(); } }
                            }
                        }

                        VerticalBox {
                            visible: root.settings-active-section == "torrenting";
                            spacing: 8px;
                            Text { text: "Torrenting"; font-size: 16px; font-weight: 700; color: #111827; }
                            CheckBox { text: "Enable torrents"; checked: root.settings-torrent-enabled; toggled => { root.settings-torrent-enabled-changed(self.checked); } }
                            Text { text: "Torrent directory"; font-size: 12px; color: #374151; }
                            HorizontalBox {
                                spacing: 8px;
                                LineEdit { text: root.settings-torrent-download-directory; horizontal-stretch: 1; edited => { root.settings-torrent-download-directory-changed(self.text); } }
                                Button { text: "Browse"; clicked => { root.settings-browse-torrent-directory-requested(); } }
                            }
                            Text { text: "Seed stop policy"; font-size: 12px; color: #374151; }
                            HorizontalBox {
                                spacing: 6px;
                                Button { text: "Forever"; checked: root.settings-torrent-seed-mode == "forever"; clicked => { root.settings-torrent-seed-mode-changed("forever"); } }
                                Button { text: "Ratio"; checked: root.settings-torrent-seed-mode == "ratio"; clicked => { root.settings-torrent-seed-mode-changed("ratio"); } }
                                Button { text: "Time"; checked: root.settings-torrent-seed-mode == "time"; clicked => { root.settings-torrent-seed-mode-changed("time"); } }
                                Button { text: "Ratio or time"; checked: root.settings-torrent-seed-mode == "ratio_or_time"; clicked => { root.settings-torrent-seed-mode-changed("ratio_or_time"); } }
                            }
                            HorizontalBox {
                                spacing: 8px;
                                LineEdit { text: root.settings-torrent-seed-ratio-limit; placeholder-text: "Ratio"; edited => { root.settings-torrent-seed-ratio-limit-changed(self.text); } }
                                LineEdit { text: root.settings-torrent-seed-time-limit-minutes; placeholder-text: "Minutes"; edited => { root.settings-torrent-seed-time-limit-minutes-changed(self.text); } }
                                LineEdit { text: root.settings-torrent-upload-limit-kib-per-second; placeholder-text: "Upload KiB/s"; edited => { root.settings-torrent-upload-limit-kib-per-second-changed(self.text); } }
                            }
                            CheckBox { text: "Enable port forwarding"; checked: root.settings-torrent-port-forwarding-enabled; toggled => { root.settings-torrent-port-forwarding-enabled-changed(self.checked); } }
                            HorizontalBox {
                                spacing: 8px;
                                LineEdit { text: root.settings-torrent-port-forwarding-port; placeholder-text: "Port"; edited => { root.settings-torrent-port-forwarding-port-changed(self.text); } }
                                Button { text: "Diagnose"; checked: root.settings-torrent-peer-watchdog-mode == "diagnose"; clicked => { root.settings-torrent-peer-watchdog-mode-changed("diagnose"); } }
                                Button { text: "Experimental"; checked: root.settings-torrent-peer-watchdog-mode == "experimental"; clicked => { root.settings-torrent-peer-watchdog-mode-changed("experimental"); } }
                            }
                            Button { text: root.settings-cache-clearing ? "Clearing..." : "Clear torrent session cache"; clicked => { root.settings-clear-torrent-cache-requested(); } }
                        }

                        VerticalBox {
                            visible: root.settings-active-section == "appearance";
                            spacing: 8px;
                            Text { text: "Appearance/Behavior"; font-size: 16px; font-weight: 700; color: #111827; }
                            CheckBox { text: "Start on startup"; checked: root.settings-start-on-startup; toggled => { root.settings-start-on-startup-changed(self.checked); } }
                            HorizontalBox {
                                spacing: 6px;
                                Button { text: "Open"; checked: root.settings-startup-launch-mode == "open"; clicked => { root.settings-startup-launch-mode-changed("open"); } }
                                Button { text: "Tray"; checked: root.settings-startup-launch-mode == "tray"; clicked => { root.settings-startup-launch-mode-changed("tray"); } }
                            }
                            Text { text: "Theme"; font-size: 12px; color: #374151; }
                            HorizontalBox {
                                spacing: 6px;
                                Button { text: "System"; checked: root.settings-theme == "system"; clicked => { root.settings-theme-changed("system"); } }
                                Button { text: "Light"; checked: root.settings-theme == "light"; clicked => { root.settings-theme-changed("light"); } }
                                Button { text: "Dark"; checked: root.settings-theme == "dark"; clicked => { root.settings-theme-changed("dark"); } }
                                Button { text: "OLED"; checked: root.settings-theme == "oled_dark"; clicked => { root.settings-theme-changed("oled_dark"); } }
                            }
                            Text { text: "Accent color"; font-size: 12px; color: #374151; }
                            LineEdit { text: root.settings-accent-color; edited => { root.settings-accent-color-changed(self.text); } }
                        }

                        VerticalBox {
                            visible: root.settings-active-section == "extension";
                            spacing: 8px;
                            Text { text: "Web Extension"; font-size: 16px; font-weight: 700; color: #111827; }
                            CheckBox { text: "Enable browser extension integration"; checked: root.settings-extension-enabled; toggled => { root.settings-extension-enabled-changed(self.checked); } }
                            Text { text: "Download handoff mode"; font-size: 12px; color: #374151; }
                            HorizontalBox {
                                spacing: 6px;
                                Button { text: "Off"; checked: root.settings-extension-handoff-mode == "off"; clicked => { root.settings-extension-handoff-mode-changed("off"); } }
                                Button { text: "Ask"; checked: root.settings-extension-handoff-mode == "ask"; clicked => { root.settings-extension-handoff-mode-changed("ask"); } }
                                Button { text: "Auto"; checked: root.settings-extension-handoff-mode == "auto"; clicked => { root.settings-extension-handoff-mode-changed("auto"); } }
                            }
                            LineEdit { text: root.settings-extension-listen-port; placeholder-text: "Listen port"; edited => { root.settings-extension-listen-port-changed(self.text); } }
                            CheckBox { text: "Browser context menu"; checked: root.settings-extension-context-menu-enabled; toggled => { root.settings-extension-context-menu-enabled-changed(self.checked); } }
                            CheckBox { text: "Show progress after handoff"; checked: root.settings-extension-show-progress-after-handoff; toggled => { root.settings-extension-show-progress-after-handoff-changed(self.checked); } }
                            CheckBox { text: "Show badge status"; checked: root.settings-extension-show-badge-status; toggled => { root.settings-extension-show-badge-status-changed(self.checked); } }
                            CheckBox { text: "Protected download handoff"; checked: root.settings-extension-authenticated-handoff-enabled; toggled => { root.settings-extension-authenticated-handoff-enabled-changed(self.checked); } }
                            Text { text: root.settings-extension-excluded-hosts-summary; font-size: 12px; color: #586174; }
                            HorizontalBox {
                                spacing: 8px;
                                LineEdit { text: root.settings-extension-excluded-host-input; horizontal-stretch: 1; placeholder-text: "example.com, *.example.org"; edited => { root.settings-extension-excluded-host-input-changed(self.text); } }
                                Button { text: "Add"; clicked => { root.settings-extension-excluded-host-add-requested(); } }
                            }
                            ListView {
                                height: 120px;
                                for host in root.settings-extension-excluded-hosts: Rectangle {
                                    height: 30px;
                                    HorizontalBox {
                                        spacing: 8px;
                                        Text { text: host; font-size: 12px; color: #1f2937; horizontal-stretch: 1; overflow: elide; }
                                        Button { text: "Remove"; clicked => { root.settings-extension-excluded-host-remove-requested(host); } }
                                    }
                                }
                            }
                        }

                        VerticalBox {
                            visible: root.settings-active-section == "native_host";
                            spacing: 10px;
                            HorizontalBox {
                                spacing: 8px;
                                Text { text: "Native Host"; font-size: 16px; font-weight: 700; color: #111827; horizontal-stretch: 1; }
                                Button { text: root.diagnostics-loading ? "Refreshing..." : "Refresh"; clicked => { root.diagnostics-refresh-requested(); } }
                            }

                            Rectangle {
                                border-color: #d5dae3;
                                border-width: 1px;
                                border-radius: 6px;
                                background: #f8fafc;
                                min-height: 94px;
                                VerticalBox {
                                    padding: 12px;
                                    spacing: 6px;
                                    HorizontalBox {
                                        spacing: 8px;
                                        Text { text: root.diagnostics-status-label; font-size: 14px; font-weight: 700; color: root.diagnostics-status-tone == "error" ? #b91c1c : root.diagnostics-status-tone == "warning" ? #b45309 : root.diagnostics-status-tone == "success" ? #047857 : #586174; }
                                        Rectangle { horizontal-stretch: 1; }
                                        Button { text: "Open Docs"; clicked => { root.diagnostics-open-install-docs-requested(); } }
                                    }
                                    Text { text: root.diagnostics-status-message; font-size: 12px; color: #374151; wrap: word-wrap; }
                                    Text { text: root.diagnostics-queue-summary + " | Last host contact: " + root.diagnostics-last-host-contact; font-size: 12px; color: #586174; }
                                }
                            }

                            HorizontalBox {
                                spacing: 8px;
                                Button { text: "Copy Diagnostics"; clicked => { root.diagnostics-copy-requested(); } }
                                Button { text: "Export Report"; clicked => { root.diagnostics-export-requested(); } }
                                Button { text: "Repair Host Registration"; clicked => { root.diagnostics-repair-host-requested(); } }
                                Button { text: "Test Handoff"; clicked => { root.diagnostics-test-handoff-requested(); } }
                            }

                            Text { visible: root.diagnostics-action-status-text != ""; text: root.diagnostics-action-status-text; font-size: 12px; color: #047857; }
                            Text { visible: root.diagnostics-error-text != ""; text: root.diagnostics-error-text; font-size: 12px; color: #b91c1c; wrap: word-wrap; }

                            Text { text: "Browser registrations"; font-size: 13px; font-weight: 700; color: #111827; }
                            ListView {
                                height: 155px;
                                for entry in root.diagnostics-host-entries: Rectangle {
                                    height: 66px;
                                    border-color: #e5e7eb;
                                    border-width: 1px;
                                    border-radius: 4px;
                                    background: #ffffff;
                                    VerticalBox {
                                        padding: 8px;
                                        spacing: 3px;
                                        HorizontalBox {
                                            Text { text: entry.browser; font-size: 13px; font-weight: 700; color: #111827; horizontal-stretch: 1; overflow: elide; }
                                            Text { text: entry.status-label; font-size: 12px; color: entry.status-tone == "warning" ? #b45309 : entry.status-tone == "success" ? #047857 : #586174; }
                                        }
                                        Text { text: "Registry: " + entry.registry-path; font-size: 11px; color: #586174; overflow: elide; }
                                        Text { text: "Manifest: " + entry.manifest-path; font-size: 11px; color: #586174; overflow: elide; }
                                        Text { text: "Host: " + entry.host-binary-path; font-size: 11px; color: #586174; overflow: elide; }
                                    }
                                }
                            }

                            Text { text: "Recent diagnostic events"; font-size: 13px; font-weight: 700; color: #111827; }
                            ListView {
                                height: 150px;
                                for event in root.diagnostics-recent-events: Rectangle {
                                    height: 54px;
                                    border-color: #e5e7eb;
                                    border-width: 1px;
                                    border-radius: 4px;
                                    background: #ffffff;
                                    VerticalBox {
                                        padding: 8px;
                                        spacing: 3px;
                                        HorizontalBox {
                                            Text { text: event.level; font-size: 11px; font-weight: 700; color: event.level-tone == "error" ? #b91c1c : event.level-tone == "warning" ? #b45309 : #047857; }
                                            Rectangle { horizontal-stretch: 1; }
                                            Text { text: event.timestamp-text; font-size: 11px; color: #586174; }
                                        }
                                        Text { text: event.message; font-size: 12px; color: #111827; overflow: elide; }
                                        Text { text: event.job-id == "" ? event.category : event.category + " / " + event.job-id; font-size: 11px; color: #586174; overflow: elide; }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

        Rectangle {
            visible: root.settings-unsaved-prompt-visible;
            width: parent.width;
            height: parent.height;
            background: #00000080;

            Rectangle {
                width: 420px;
                height: 190px;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                border-color: #d5dae3;
                border-width: 1px;
                border-radius: 6px;
                background: #ffffff;

                VerticalBox {
                    padding: 18px;
                    spacing: 12px;
                    Text { text: "Discard settings changes?"; font-size: 16px; font-weight: 700; color: #111827; }
                    Text { text: "Your settings draft has unsaved changes."; font-size: 12px; color: #586174; }
                    Rectangle { vertical-stretch: 1; }
                    HorizontalBox {
                        spacing: 8px;
                        Rectangle { horizontal-stretch: 1; }
                        Button { text: "Keep Editing"; clicked => { root.settings-unsaved-cancelled(); } }
                        Button { text: "Discard"; clicked => { root.settings-discard-confirmed(); } }
                    }
                }
            }
        }
    }

    Rectangle {
        visible: root.add-download-visible;
        width: root.width;
        height: root.height;
        background: #00000080;

        Rectangle {
            width: 600px;
            height: 520px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            border-color: #d5dae3;
            border-width: 1px;
            border-radius: 6px;
            background: #ffffff;

            VerticalBox {
                padding: 18px;
                spacing: 10px;

                HorizontalBox {
                    spacing: 8px;

                    VerticalBox {
                        horizontal-stretch: 1;
                        spacing: 2px;
                        Text { text: "New Download"; font-size: 16px; font-weight: 700; color: #111827; }
                        Text { text: "Add a file, torrent, link list, or bulk archive."; font-size: 12px; color: #586174; }
                    }

                    Button { text: "Close"; clicked => { root.add-download-cancelled(); } }
                }

                HorizontalBox {
                    spacing: 6px;
                    Button { text: "File"; checked: root.add-download-mode == "single"; clicked => { root.add-download-mode-changed("single"); } }
                    Button { text: "Torrent"; checked: root.add-download-mode == "torrent"; clicked => { root.add-download-mode-changed("torrent"); } }
                    Button { text: "Multi"; checked: root.add-download-mode == "multi"; clicked => { root.add-download-mode-changed("multi"); } }
                    Button { text: "Bulk"; checked: root.add-download-mode == "bulk"; clicked => { root.add-download-mode-changed("bulk"); } }
                }

                VerticalBox {
                    visible: root.add-download-mode == "single";
                    spacing: 6px;
                    Text { text: "File URL"; font-size: 12px; color: #374151; }
                    LineEdit {
                        text: root.add-download-single-url;
                        placeholder-text: "https://example.com/file.zip";
                        edited => {
                            root.add-download-single-url-changed(self.text);
                        }
                    }
                    Text { text: "SHA-256 Checksum"; font-size: 12px; color: #374151; }
                    LineEdit {
                        text: root.add-download-single-sha256;
                        placeholder-text: "64-character hex digest";
                        edited => {
                            root.add-download-single-sha256-changed(self.text);
                        }
                    }
                }

                VerticalBox {
                    visible: root.add-download-mode == "torrent";
                    spacing: 6px;
                    Text { text: "Torrent URL"; font-size: 12px; color: #374151; }
                    LineEdit {
                        text: root.add-download-torrent-url;
                        placeholder-text: "magnet:?xt=urn:btih:... or C:/Downloads/file.torrent";
                        edited => {
                            root.add-download-torrent-url-changed(self.text);
                        }
                    }
                    Button {
                        text: root.add-download-importing ? "Importing..." : "Import";
                        enabled: !root.add-download-importing;
                        clicked => {
                            root.add-download-import-torrent-requested();
                        }
                    }
                }

                VerticalBox {
                    visible: root.add-download-mode == "multi";
                    spacing: 6px;
                    Text { text: "Download URLs"; font-size: 12px; color: #374151; }
                    multi-urls := TextEdit {
                        height: 172px;
                        wrap: TextWrap.no-wrap;
                        font-family: "monospace";
                        font-size: 13px;
                        text: root.add-download-multi-urls;
                        placeholder-text: "https://example.com/file-01.zip\nhttps://example.com/file-02.zip";
                        edited => {
                            root.add-download-multi-urls-changed(multi-urls.text);
                        }
                    }
                }

                VerticalBox {
                    visible: root.add-download-mode == "bulk";
                    spacing: 6px;
                    Text { text: "Bulk Links"; font-size: 12px; color: #374151; }
                    bulk-urls := TextEdit {
                        height: 138px;
                        wrap: TextWrap.no-wrap;
                        font-family: "monospace";
                        font-size: 13px;
                        text: root.add-download-bulk-urls;
                        placeholder-text: "https://example.com/assets/model.fbx\nhttps://example.com/assets/textures.zip";
                        edited => {
                            root.add-download-bulk-urls-changed(bulk-urls.text);
                        }
                    }
                    CheckBox {
                        text: "Combine into one archive";
                        checked: root.add-download-combine-bulk;
                        toggled => {
                            root.add-download-combine-bulk-changed(self.checked);
                        }
                    }
                    LineEdit {
                        enabled: root.add-download-combine-bulk;
                        text: root.add-download-archive-name;
                        placeholder-text: "bulk-download.zip";
                        edited => {
                            root.add-download-archive-name-changed(self.text);
                        }
                    }
                }

                Rectangle {
                    height: 36px;
                    border-color: #d5dae3;
                    border-width: 1px;
                    border-radius: 4px;
                    background: #f9fafb;

                    HorizontalBox {
                        padding-left: 10px;
                        padding-right: 10px;
                        spacing: 8px;
                        Text { text: root.add-download-ready-label; font-size: 12px; color: #586174; vertical-alignment: center; horizontal-stretch: 1; }
                        Text { text: root.add-download-ready-detail; font-size: 12px; color: #586174; vertical-alignment: center; overflow: elide; }
                    }
                }

                Text {
                    visible: root.add-download-error-text != "";
                    text: root.add-download-error-text;
                    color: #b91c1c;
                    font-size: 12px;
                    wrap: word-wrap;
                }

                HorizontalBox {
                    spacing: 8px;
                    horizontal-stretch: 1;
                    Rectangle { horizontal-stretch: 1; }
                    Button { text: "Cancel"; clicked => { root.add-download-cancelled(); } }
                    Button {
                        text: root.add-download-submitting ? "Adding..." : root.add-download-submit-label;
                        enabled: root.add-download-can-submit && !root.add-download-submitting;
                        clicked => {
                            root.add-download-submit-requested();
                        }
                    }
                }
            }
        }
    }

    Rectangle {
        visible: root.rename-prompt-visible;
        width: root.width;
        height: root.height;
        background: #00000080;

        Rectangle {
            width: 440px;
            height: 260px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            border-color: #d5dae3;
            border-width: 1px;
            border-radius: 6px;
            background: #ffffff;

            VerticalBox {
                padding: 18px;
                spacing: 10px;

                Text { text: "Rename Download"; font-size: 16px; font-weight: 700; color: #111827; }
                Text { text: root.rename-original-filename; font-size: 12px; color: #586174; overflow: elide; }
                Text { text: "Name"; font-size: 12px; color: #374151; }
                LineEdit {
                    text: root.rename-base-name;
                    edited => {
                        root.rename-base-name-changed(self.text);
                    }
                }
                Text { text: "Extension"; font-size: 12px; color: #374151; }
                LineEdit {
                    text: root.rename-extension;
                    edited => {
                        root.rename-extension-changed(self.text);
                    }
                }
                Text { text: "Result: " + (root.rename-preview-filename == "" ? "Enter a file name." : root.rename-preview-filename); font-size: 11px; color: #586174; overflow: elide; }

                HorizontalBox {
                    spacing: 8px;
                    horizontal-stretch: 1;
                    Rectangle { horizontal-stretch: 1; }
                    Button { text: "Cancel"; clicked => { root.rename-cancelled(); } }
                    Button { text: "Rename"; enabled: root.rename-can-confirm; clicked => { root.rename-confirmed(); } }
                }
            }
        }
    }

    Rectangle {
        visible: root.delete-prompt-visible;
        width: root.width;
        height: root.height;
        background: #00000080;

        Rectangle {
            width: 460px;
            height: 360px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            border-color: #d5dae3;
            border-width: 1px;
            border-radius: 6px;
            background: #ffffff;

            VerticalBox {
                padding: 18px;
                spacing: 10px;

                Text { text: root.delete-prompt-title; font-size: 16px; font-weight: 700; color: #111827; }
                Text { text: root.delete-prompt-description; font-size: 12px; color: #586174; wrap: word-wrap; }
                Text { text: root.delete-prompt-selected-summary; font-size: 12px; color: #111827; font-weight: 700; }

                ListView {
                    height: 104px;
                    viewport-width: parent.width;
                    viewport-height: self.height;
                    for item in root.delete-prompt-jobs: Rectangle {
                        height: 34px;
                        width: parent.width;
                        background: #f9fafb;
                        VerticalBox {
                            padding-left: 8px;
                            padding-right: 8px;
                            spacing: 1px;
                            Text { text: item.filename; font-size: 12px; color: #111827; overflow: elide; }
                            Text { text: item.target-path == "" ? root.delete-prompt-missing-path-label : item.target-path; font-size: 10px; color: #586174; overflow: elide; }
                        }
                    }
                }

                Button {
                    text: (root.delete-prompt-delete-from-disk ? "[x] " : "[ ] ") + root.delete-prompt-checkbox-label;
                    clicked => {
                        root.delete-from-disk-changed(!root.delete-prompt-delete-from-disk);
                    }
                }

                HorizontalBox {
                    spacing: 8px;
                    horizontal-stretch: 1;
                    Rectangle { horizontal-stretch: 1; }
                    Button { text: "Cancel"; clicked => { root.delete-cancelled(); } }
                    Button { text: root.delete-prompt-confirm-label; clicked => { root.delete-confirmed(); } }
                }
            }
        }
    }

    ToastArea {
        x: root.width - self.width - 24px;
        y: root.height - self.height - 24px;
        toasts: root.toasts;
        dismiss-requested(id) => {
            root.toast-dismiss-requested(id);
        }
    }
}

component PopupHeader inherits Rectangle {
    in property <string> title;
    height: 34px;
    background: #111827;

    Text {
        text: root.title;
        color: #ffffff;
        font-size: 13px;
        font-weight: 700;
        vertical-alignment: center;
        x: 12px;
        width: parent.width - 24px;
        height: parent.height;
        overflow: elide;
    }
}

component MetaLine inherits HorizontalBox {
    in property <string> label;
    in property <string> value;
    spacing: 8px;

    Text {
        text: root.label;
        color: #586174;
        font-size: 11px;
        width: 84px;
        overflow: elide;
    }

    Text {
        text: root.value;
        color: #111827;
        font-size: 11px;
        horizontal-stretch: 1;
        overflow: elide;
    }
}

component ProgressLine inherits Rectangle {
    in property <float> progress;
    height: 8px;
    border-color: #d5dae3;
    border-width: 1px;
    border-radius: 4px;
    background: #f5f7fb;

    Rectangle {
        x: 0px;
        y: 0px;
        height: parent.height;
        width: parent.width * root.progress / 100;
        border-radius: 4px;
        background: #2563eb;
    }
}

export component DownloadPromptWindow inherits Window {
    title: prompt.title;
    preferred-width: 460px;
    preferred-height: 280px;
    min-width: 460px;
    min-height: 280px;
    max-width: 460px;
    max-height: 280px;

    in property <PromptDetails> prompt;
    callback change-directory-requested();
    callback cancel-requested();
    callback download-requested();
    callback swap-requested();
    callback duplicate-menu-toggled();
    callback duplicate-action-requested(string);
    callback duplicate-rename-started();
    callback duplicate-renamed-filename-changed(string);
    callback duplicate-rename-confirmed();
    callback duplicate-rename-cancelled();

    VerticalBox {
        PopupHeader {
            title: prompt.title;
        }

        VerticalBox {
            padding: 12px;
            spacing: 7px;

            Text {
                text: prompt.filename;
                font-size: 15px;
                font-weight: 700;
                color: #111827;
                overflow: elide;
            }

            MetaLine { label: "Source"; value: prompt.source-label; }
            MetaLine { label: "Destination"; value: prompt.destination; }
            MetaLine { label: "File size"; value: prompt.size-text; }
            MetaLine { label: "Detected by"; value: prompt.url; }

            Text {
                text: prompt.duplicate-message + prompt.duplicate-label;
                color: #92400e;
                font-size: 11px;
                overflow: elide;
                visible: prompt.is-duplicate;
            }

            Text {
                text: prompt.error-text;
                color: #b91c1c;
                font-size: 11px;
                overflow: elide;
                visible: prompt.error-text != "";
            }

            Rectangle {
                height: prompt.is-duplicate && prompt.renaming-duplicate ? 34px : 0px;
                visible: prompt.is-duplicate && prompt.renaming-duplicate;
                HorizontalBox {
                    spacing: 6px;
                    LineEdit {
                        text: prompt.renamed-filename;
                        placeholder-text: "New file name";
                        horizontal-stretch: 1;
                        edited => {
                            root.duplicate-renamed-filename-changed(self.text);
                        }
                    }
                    Button { text: "Cancel"; clicked => { root.duplicate-rename-cancelled(); } }
                    Button {
                        text: prompt.busy ? "Renaming..." : "Rename";
                        enabled: prompt.rename-can-confirm && !prompt.busy;
                        clicked => { root.duplicate-rename-confirmed(); }
                    }
                }
            }

            HorizontalBox {
                spacing: 6px;

                Button {
                    text: "Change";
                    enabled: !prompt.busy;
                    clicked => { root.change-directory-requested(); }
                }
                Button {
                    text: "Cancel";
                    enabled: !prompt.busy;
                    clicked => { root.cancel-requested(); }
                }
                Button {
                    text: "Swap";
                    visible: prompt.can-swap-to-browser;
                    enabled: !prompt.busy;
                    clicked => { root.swap-requested(); }
                }
                Button {
                    text: prompt.busy ? "Starting..." : "Download";
                    visible: !prompt.is-duplicate;
                    enabled: !prompt.busy;
                    clicked => { root.download-requested(); }
                }
                Button {
                    text: "Choose Action";
                    visible: prompt.is-duplicate && !prompt.renaming-duplicate;
                    enabled: !prompt.busy;
                    clicked => { root.duplicate-menu-toggled(); }
                }
            }

            HorizontalBox {
                spacing: 6px;
                visible: prompt.is-duplicate && prompt.duplicate-menu-open && !prompt.renaming-duplicate;

                Button {
                    text: "Overwrite";
                    enabled: !prompt.busy;
                    clicked => { root.duplicate-action-requested("overwrite"); }
                }
                Button {
                    text: "Rename";
                    enabled: !prompt.busy;
                    clicked => { root.duplicate-rename-started(); }
                }
                Button {
                    text: "Download Anyway";
                    enabled: !prompt.busy;
                    clicked => { root.duplicate-action-requested("download_anyway"); }
                }
            }
        }
    }
}

export component HttpProgressWindow inherits Window {
    title: details.title;
    preferred-width: 460px;
    preferred-height: 280px;
    min-width: 460px;
    min-height: 280px;
    max-width: 460px;
    max-height: 280px;

    in property <ProgressDetails> details;
    callback progress-pause-requested(string);
    callback progress-resume-requested(string);
    callback progress-retry-requested(string);
    callback progress-cancel-requested(string);
    callback progress-open-requested(string);
    callback progress-reveal-requested(string);
    callback progress-swap-requested(string);
    callback progress-close-requested(string);

    VerticalBox {
        PopupHeader { title: details.title; }

        VerticalBox {
            padding: 12px;
            spacing: 7px;

            Text {
                text: details.filename;
                font-size: 15px;
                font-weight: 700;
                color: #111827;
                overflow: elide;
            }

            MetaLine { label: "State"; value: details.state; }
            MetaLine { label: "Source"; value: details.subtitle; }
            MetaLine { label: "Path"; value: details.destination; }
            ProgressLine { progress: details.progress; }

            HorizontalBox {
                spacing: 8px;
                MetaLine { label: "Speed"; value: details.speed-text; horizontal-stretch: 1; }
                MetaLine { label: "ETA"; value: details.eta-text; horizontal-stretch: 1; }
                MetaLine { label: "Size"; value: details.size-text; horizontal-stretch: 1; }
            }

            Text {
                text: details.progress-label + " | " + details.bytes-text;
                color: #586174;
                font-size: 11px;
                overflow: elide;
            }

            Text {
                text: details.action-error-text != "" ? details.action-error-text : details.error-text;
                color: #b91c1c;
                font-size: 11px;
                overflow: elide;
                visible: details.action-error-text != "" || details.error-text != "";
            }

            HorizontalBox {
                spacing: 6px;
                Button { text: "Open"; enabled: details.can-open && !details.busy; clicked => { root.progress-open-requested(details.id); } }
                Button { text: "Show"; enabled: details.can-reveal && !details.busy; clicked => { root.progress-reveal-requested(details.id); } }
                Button { text: "Pause"; visible: details.can-pause; enabled: !details.busy; clicked => { root.progress-pause-requested(details.id); } }
                Button { text: "Resume"; visible: details.can-resume; enabled: !details.busy; clicked => { root.progress-resume-requested(details.id); } }
                Button { text: "Retry"; visible: details.can-retry; enabled: !details.busy; clicked => { root.progress-retry-requested(details.id); } }
                Button { text: "Swap"; visible: details.can-swap-to-browser; enabled: !details.busy; clicked => { root.progress-swap-requested(details.id); } }
                Button {
                    text: details.cancel-confirming ? "Confirm cancel" : "Cancel";
                    visible: details.can-cancel;
                    enabled: !details.busy;
                    clicked => { root.progress-cancel-requested(details.id); }
                }
                Button { text: "Close"; enabled: !details.busy; clicked => { root.progress-close-requested(details.id); } }
            }
        }
    }
}

export component TorrentProgressWindow inherits Window {
    title: details.title;
    preferred-width: 720px;
    preferred-height: 520px;
    min-width: 720px;
    min-height: 520px;
    max-width: 720px;
    max-height: 520px;

    in property <ProgressDetails> details;
    callback progress-pause-requested(string);
    callback progress-resume-requested(string);
    callback progress-retry-requested(string);
    callback progress-cancel-requested(string);
    callback progress-open-requested(string);
    callback progress-reveal-requested(string);
    callback progress-swap-requested(string);
    callback progress-close-requested(string);

    VerticalBox {
        PopupHeader { title: details.title; }

        VerticalBox {
            padding: 14px;
            spacing: 10px;

            Text {
                text: details.filename;
                font-size: 16px;
                font-weight: 700;
                color: #111827;
                overflow: elide;
            }

            MetaLine { label: "State"; value: details.state; }
            MetaLine { label: "Source"; value: details.source-summary; }
            MetaLine { label: "Hash"; value: details.info-hash; }
            MetaLine { label: "Files"; value: details.files-text; }
            ProgressLine { progress: details.progress; }

            HorizontalBox {
                spacing: 8px;
                MetaLine { label: "Down"; value: details.speed-text; horizontal-stretch: 1; }
                MetaLine { label: "Up"; value: details.upload-speed-text; horizontal-stretch: 1; }
                MetaLine { label: "ETA"; value: details.eta-text; horizontal-stretch: 1; }
            }

            HorizontalBox {
                spacing: 8px;
                MetaLine { label: "Peers"; value: details.peers-text; horizontal-stretch: 1; }
                MetaLine { label: "Seeds"; value: details.seeds-text; horizontal-stretch: 1; }
                MetaLine { label: "Ratio"; value: details.ratio-text; horizontal-stretch: 1; }
            }

            MetaLine { label: "Path"; value: details.destination; }

            Text {
                text: details.progress-label + " | " + details.bytes-text + " | " + details.remaining-text;
                color: #586174;
                font-size: 11px;
                overflow: elide;
            }

            Text {
                text: details.action-error-text != "" ? details.action-error-text : details.error-text;
                color: #b91c1c;
                font-size: 11px;
                overflow: elide;
                visible: details.action-error-text != "" || details.error-text != "";
            }

            HorizontalBox {
                spacing: 6px;
                Button { text: "Open"; enabled: details.can-open && !details.busy; clicked => { root.progress-open-requested(details.id); } }
                Button { text: "Show"; enabled: details.can-reveal && !details.busy; clicked => { root.progress-reveal-requested(details.id); } }
                Button { text: "Pause"; visible: details.can-pause; enabled: !details.busy; clicked => { root.progress-pause-requested(details.id); } }
                Button { text: "Resume"; visible: details.can-resume; enabled: !details.busy; clicked => { root.progress-resume-requested(details.id); } }
                Button { text: "Retry"; visible: details.can-retry; enabled: !details.busy; clicked => { root.progress-retry-requested(details.id); } }
                Button { text: "Swap"; visible: details.can-swap-to-browser; enabled: !details.busy; clicked => { root.progress-swap-requested(details.id); } }
                Button {
                    text: details.cancel-confirming ? "Confirm cancel" : "Cancel";
                    visible: details.can-cancel;
                    enabled: !details.busy;
                    clicked => { root.progress-cancel-requested(details.id); }
                }
                Button { text: "Close"; enabled: !details.busy; clicked => { root.progress-close-requested(details.id); } }
            }
        }
    }
}

export component BatchProgressWindow inherits Window {
    title: details.title;
    preferred-width: 560px;
    preferred-height: 430px;
    min-width: 560px;
    min-height: 430px;
    max-width: 560px;
    max-height: 430px;

    in property <BatchDetails> details;
    callback batch-pause-requested(string);
    callback batch-resume-requested(string);
    callback batch-cancel-requested(string);
    callback batch-reveal-completed-requested(string);
    callback batch-close-requested(string);

    VerticalBox {
        PopupHeader { title: details.title; }

        VerticalBox {
            padding: 14px;
            spacing: 10px;

            Text {
                text: details.display-title;
                font-size: 15px;
                font-weight: 700;
                color: #111827;
                overflow: elide;
            }

            MetaLine { label: "Batch"; value: details.summary; }
            MetaLine { label: "Phase"; value: details.phase-label; }
            MetaLine { label: "Bytes"; value: details.bytes-text; }
            ProgressLine { progress: details.progress; }

            ListView {
                height: 204px;
                viewport-width: parent.width;
                viewport-height: self.height;
                for row in details.rows: Rectangle {
                    height: 46px;
                    width: parent.width;
                    background: #f9fafb;
                    VerticalBox {
                        padding-left: 8px;
                        padding-right: 8px;
                        spacing: 2px;
                        Text { text: row.filename; font-size: 12px; color: #111827; overflow: elide; }
                        Text { text: row.status-text + " | " + row.progress-label + " | " + row.size-text; font-size: 10px; color: #586174; overflow: elide; }
                    }
                }
            }

            Text {
                text: details.action-error-text != "" ? details.action-error-text : details.archive-error;
                color: #b91c1c;
                font-size: 11px;
                overflow: elide;
                visible: details.action-error-text != "" || details.archive-error != "";
            }

            HorizontalBox {
                spacing: 6px;
                Button { text: "Pause all"; enabled: details.can-pause && !details.busy; clicked => { root.batch-pause-requested(details.batch-id); } }
                Button { text: "Resume all"; enabled: details.can-resume && !details.busy; clicked => { root.batch-resume-requested(details.batch-id); } }
                Button { text: "Cancel active"; enabled: details.can-cancel && !details.busy; clicked => { root.batch-cancel-requested(details.batch-id); } }
                Button { text: "Reveal completed"; enabled: details.can-reveal-completed && !details.busy; clicked => { root.batch-reveal-completed-requested(details.batch-id); } }
                Button { text: "Close"; enabled: !details.busy; clicked => { root.batch-close-requested(details.batch-id); } }
            }
        }
    }
}
