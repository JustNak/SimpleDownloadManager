}

export component BatchProgressWindow inherits Window {
    title: details.title;
    preferred-width: 560px;
    preferred-height: 430px;
    min-width: 560px;
    min-height: 430px;
    max-width: 560px;
    max-height: 430px;

    in property <BatchDetails> details;

    VerticalBox {
        PopupHeader { title: details.title; }

        VerticalBox {
            padding: 14px;
            spacing: 10px;

            Text {
                text: details.summary;
                font-size: 15px;
                font-weight: 700;
                color: #111827;
                overflow: elide;
            }

            MetaLine { label: "Batch"; value: details.batch-id; }
            MetaLine { label: "Bytes"; value: details.bytes-text; }
