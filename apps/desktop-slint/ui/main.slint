import { Button, CheckBox, HorizontalBox, LineEdit, ListView, TextEdit, VerticalBox } from "std-widgets.slint";

export struct JobRow {
    id: string,
    filename: string,
    state: string,
    progress: float,
    bytes-text: string,
    selected: bool,
    transfer-kind: string,
    created-text: string,
    size-text: string,
    speed-text: string,
    status-detail: string,
    status-tone: string,
    can-pause: bool,
    can-resume: bool,
    can-cancel: bool,
    can-retry: bool,
    can-restart: bool,
    can-remove: bool,
    can-show-progress: bool,
    target-path: string,
    delete-label: string,
    can-open: bool,
    can-reveal: bool,
    can-swap-to-browser: bool,
    can-rename: bool,
}

export struct QueueNavItem {
    id: string,
    label: string,
    count: int,
    active: bool,
    section: string,
}

export struct SettingsNavItem {
    id: string,
    label: string,
    active: bool,
}

export struct HostRegistrationEntryRow {
    browser: string,
    registry-path: string,
    manifest-path: string,
    host-binary-path: string,
    manifest-exists: bool,
    host-binary-exists: bool,
    status-label: string,
    status-tone: string,
}

export struct DiagnosticEventRow {
    level: string,
    level-tone: string,
    timestamp-text: string,
    message: string,
    category: string,
    job-id: string,
}

export struct TorrentDiagnosticRow {
    job-id: string,
    filename: string,
    info-hash: string,
    summary: string,
}

export struct DeletePromptJob {
    id: string,
    filename: string,
    target-path: string,
}

export struct PromptDetails {
    id: string,
    title: string,
    filename: string,
    url: string,
    destination: string,
    size-text: string,
    duplicate-text: string,
    is-duplicate: bool,
    duplicate-label: string,
    duplicate-message: string,
    overwrite-label: string,
    source-label: string,
    can-swap-to-browser: bool,
    duplicate-menu-open: bool,
    renaming-duplicate: bool,
    renamed-filename: string,
    rename-can-confirm: bool,
    busy: bool,
    error-text: string,
}

export struct ProgressDetails {
    id: string,
    title: string,
    filename: string,
    state: string,
    bytes-text: string,
    progress: float,
    error-text: string,
    subtitle: string,
    destination: string,
    status-tone: string,
    progress-label: string,
    speed-text: string,
    eta-text: string,
    size-text: string,
    source-summary: string,
    info-hash: string,
    remaining-text: string,
    upload-speed-text: string,
    peers-text: string,
    seeds-text: string,
    ratio-text: string,
    files-text: string,
    peer-health-tones: [string],
    can-open: bool,
    can-reveal: bool,
    can-pause: bool,
    can-resume: bool,
    can-retry: bool,
    can-cancel: bool,
    can-swap-to-browser: bool,
    can-close: bool,
    busy: bool,
    cancel-confirming: bool,
    action-error-text: string,
}

export struct BatchProgressJobRow {
    id: string,
    filename: string,
    subtitle: string,
    status-text: string,
    status-tone: string,
    progress: float,
    progress-label: string,
    speed-text: string,
    size-text: string,
}

export struct BatchDetails {
    batch-id: string,
    title: string,
    display-title: string,
    summary: string,
    bytes-text: string,
    progress: float,
    completed-count: int,
    failed-count: int,
    active-count: int,
    total-count: int,
    phase-id: string,
    phase-label: string,
    phase-tone: string,
    archive-error: string,
    rows: [BatchProgressJobRow],
    can-pause: bool,
    can-resume: bool,
    can-cancel: bool,
    can-reveal-completed: bool,
    reveal-completed-job-id: string,
    can-close: bool,
    busy: bool,
    action-error-text: string,
}

export struct ToastMessage {
    id: string,
    toast-type: string,
    tone: string,
    title: string,
    message: string,
    auto-close: bool,
}

component ToastArea inherits Rectangle {
    in property <[ToastMessage]> toasts;
    callback dismiss-requested(string);

    visible: root.toasts.length > 0;
    width: 360px;
    height: 360px;
    background: transparent;

    VerticalBox {
        spacing: 8px;

        Rectangle { vertical-stretch: 1; }

        for toast in root.toasts: Rectangle {
            height: 82px;
            border-width: 1px;
            border-radius: 6px;
            border-color: toast.tone == "success" ? #16a34a : toast.tone == "error" ? #dc2626 : toast.tone == "warning" ? #d97706 : #2563eb;
            background: #ffffff;

            HorizontalBox {
                padding-left: 12px;
                padding-right: 8px;
                spacing: 10px;

                Rectangle {
                    width: 8px;
                    height: 46px;
                    border-radius: 4px;
                    background: toast.tone == "success" ? #16a34a : toast.tone == "error" ? #dc2626 : toast.tone == "warning" ? #d97706 : #2563eb;
                }

                VerticalBox {
                    horizontal-stretch: 1;
                    spacing: 4px;

                    Text {
                        text: toast.title;
                        font-size: 13px;
                        font-weight: 700;
                        color: #111827;
                        overflow: elide;
                    }

                    Text {
                        text: toast.message;
                        font-size: 12px;
                        color: #586174;
                        wrap: word-wrap;
                        overflow: elide;
                    }
                }

                Button {
                    text: "X";
                    width: 34px;
                    clicked => {
                        root.dismiss-requested(toast.id);
                    }
                }
            }
        }
    }
}

export component MainWindow inherits Window {
    title: "Simple Download Manager";
    no-frame: true;
    preferred-width: 1360px;
    preferred-height: 860px;
    min-width: 1360px;
