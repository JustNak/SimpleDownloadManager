import { Button, HorizontalBox, ListView, VerticalBox } from "std-widgets.slint";

export struct JobRow {
    id: string,
    filename: string,
    state: string,
    progress: float,
    bytes-text: string,
}

export component MainWindow inherits Window {
    title: "Simple Download Manager";
    preferred-width: 1360px;
    preferred-height: 860px;
    min-width: 1024px;
    min-height: 640px;

    in property <[JobRow]> jobs;
    in property <string> status-text: "No downloads";
    callback add-download-requested();
    callback pause-job-requested(string);
    callback resume-job-requested(string);
    callback cancel-job-requested(string);
    callback open-progress-requested(string);

    VerticalBox {
        padding: 18px;
        spacing: 12px;

        HorizontalBox {
            spacing: 10px;

            Text {
                text: "Simple Download Manager";
                font-size: 22px;
                font-weight: 700;
                horizontal-stretch: 1;
            }

            Button {
                text: "Add";
                clicked => {
                    root.add-download-requested();
                }
            }
        }

        Text {
            text: root.status-text;
            color: #586174;
            font-size: 13px;
        }

        Rectangle {
            border-color: #d5dae3;
            border-width: 1px;
            border-radius: 6px;
            background: #ffffff;
            horizontal-stretch: 1;
            vertical-stretch: 1;

            ListView {
                viewport-width: parent.width;
                viewport-height: parent.height;

                for job in root.jobs: Rectangle {
                    height: 72px;
                    width: parent.width;
                    background: #ffffff;

                    HorizontalBox {
                        padding-left: 14px;
                        padding-right: 14px;
                        spacing: 12px;

                        VerticalBox {
                            horizontal-stretch: 1;
                            spacing: 4px;

                            Text {
                                text: job.filename;
                                font-size: 15px;
                                color: #111827;
                                overflow: elide;
                            }

                            Text {
                                text: job.state + " | " + job.bytes-text;
                                font-size: 12px;
                                color: #586174;
                                overflow: elide;
                            }
                        }

                        Button {
                            text: "Pause";
                            clicked => {
                                root.pause-job-requested(job.id);
                            }
                        }

                        Button {
                            text: "Resume";
                            clicked => {
                                root.resume-job-requested(job.id);
                            }
                        }

                        Button {
                            text: "Details";
                            clicked => {
                                root.open-progress-requested(job.id);
                            }
                        }
                    }
                }
            }
        }
    }
}
