{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "popups",
  "description": "Capability for download prompt and progress popup windows.",
  "windows": ["download-prompt", "download-progress-*", "torrent-progress-*", "batch-progress-*"],
  "permissions": [
    "core:event:allow-listen",
    "core:event:allow-unlisten",
    "core:window:allow-minimize",
    "core:window:allow-start-dragging",
    "core:window:allow-close"
  ]
}
