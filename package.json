{
  "name": "simple-download-manager",
  "private": true,
  "version": "0.8.7-beta",
  "workspaces": [
    "apps/desktop",
    "apps/extension",
    "packages/protocol"
  ],
  "scripts": {
    "build:extension": "npm run build --workspace @myapp/extension",
    "build:desktop": "npm run build --workspace @myapp/desktop",
    "test": "npm run test:ts && npm run test:rust",
    "test:extension": "node ./scripts/run-extension-tests.mjs",
    "test:live:bulk": "node ./scripts/run-live-bulk-test.mjs",
    "test:live:http": "node ./scripts/run-live-http-test.mjs",
    "test:live:torrent": "node ./scripts/run-live-torrent-test.mjs",
    "test:scenarios": "node ./scripts/run-scenario-tests.mjs",
    "test:soak": "node ./scripts/run-soak-tests.mjs",
    "test:ts": "node ./scripts/run-ts-tests.mjs",
    "test:rust": "node ./scripts/run-rust-tests.mjs",
    "clippy": "node ./scripts/run-clippy.mjs",
    "check": "npm run typecheck && npm test && npm run build:extension && npm run build:desktop && npm run clippy",
    "lint:firefox": "node ./scripts/lint-firefox.mjs",
    "package:firefox-amo": "npm run build:extension && node ./scripts/package-firefox-amo.mjs",
    "package:firefox-test": "npm run build:extension && node ./scripts/package-firefox-test.mjs",
    "prepare:release": "node ./scripts/prepare-release.mjs",
    "publish:updater-beta": "node ./scripts/publish-updater-beta.mjs",
    "publish:updater-alpha-bridge": "node ./scripts/publish-updater-alpha-bridge.mjs",
    "release:windows": "pwsh -ExecutionPolicy Bypass -File \"./scripts/build-release.ps1\"",
    "release:windows:x64": "pwsh -ExecutionPolicy Bypass -File \"./scripts/build-release.ps1\" -Targets x64",
    "release:windows:arm64": "pwsh -ExecutionPolicy Bypass -File \"./scripts/build-release.ps1\" -Targets arm64",
    "typecheck": "npm run typecheck --workspace @myapp/protocol && npm run typecheck --workspace @myapp/extension && npm run typecheck --workspace @myapp/desktop",
    "verify:extension": "npm run typecheck --workspace @myapp/extension && npm run build:extension && npm run test:extension && npm run lint:firefox"
  },
  "devDependencies": {
    "esbuild": "^0.25.4",
    "typescript": "^5.8.3",
    "web-ext": "^10.1.0"
  }
}
